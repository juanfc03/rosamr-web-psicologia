---
import Layout from '@/layouts/Layout.astro';
import FAQPage from '@/components/FAQPage.astro';
import { preguntas } from '@/data/faq';

const titulo = 'Preguntas frecuentes sobre mi terapia psicológica';
const descripcion =
  'Resuelve dudas sobre el precio de las sesiones, terapia online, duración del proceso y cómo empezar. Preguntas frecuentes antes de iniciar terapia.';
const canonica = `${Astro.site}preguntas-frecuentes/`;
const imagenOG = `${Astro.site}open-graph/preguntas-frecuentes.png/`;

const esquema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: preguntas.map(item => ({
    '@type': 'Question',
    name: item.pregunta,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.respuesta
        .replace(/<[^>]*>?/gm, '')
        .replace(/\s+/g, ' ')
        .trim(),
    },
  })),
};
---

<Layout
  titulo={titulo}
  descripcion={descripcion}
  canonica={canonica}
  imagenOG={imagenOG}
  esquema={esquema}
>
  <FAQPage />
</Layout>
