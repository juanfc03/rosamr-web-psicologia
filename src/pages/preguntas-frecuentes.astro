---
import Layout from '@/layouts/Layout.astro';

const titulo = 'Preguntas frecuentes sobre mi terapia psicológica';
const descripcion =
  'Resuelve dudas sobre el precio de las sesiones, terapia online, duración del proceso y cómo empezar. Preguntas frecuentes antes de iniciar terapia.';
const canonica = `${Astro.site}preguntas-frecuentes/`;
const imagenOG = `${Astro.site}open-graph/preguntas-frecuentes.png/`;

const esquema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Cuánto cuesta una sesión y cómo puedo pagar?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La sesión tiene un precio de 60 € por 60 minutos. Normalmente puede hacerse por transferencia, Bizum u otros métodos.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Trabajas con ansiedad, ataques de pánico o estrés intenso?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, atiendo casos de ansiedad generalizada, ataques de pánico y estrés mantenido. En la primera sesión valoramos tu situación, tus síntomas y qué necesitas en este momento. A partir de ahí elaboramos un plan terapéutico adaptado.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Puedo empezar directamente con terapia online?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, puedes empezar directamente online sin necesidad de acudir a consulta presencial. La terapia online funciona igual que la presencial y suele ser muy cómoda si tienes horarios complicados o vives fuera. Valoramos juntos si es el formato adecuado para ti.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuántas sesiones suelen ser necesarias?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No hay un número fijo de sesiones, depende de tu caso y tus objetivos. En la primera conversación revisamos qué necesitas y te doy una estimación orientativa del proceso para que puedas organizarte.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué pasa si no sé explicar bien lo que me ocurre?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No pasa nada: ayudarte a poner palabras a lo que sientes también forma parte de la terapia. Podemos empezar por lo que sí tienes claro, aunque sea muy poco, y construir a partir de ahí.',
      },
    },
  ],
};
---

<Layout
  titulo={titulo}
  descripcion={descripcion}
  canonica={canonica}
  imagenOG={imagenOG}
  esquema={esquema}
/>
