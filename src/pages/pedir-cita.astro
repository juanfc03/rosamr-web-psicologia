---
import Layout from '@/layouts/Layout.astro';
import FormularioContacto from '@/components/contacto/Form.astro';
import FormLegal from '@/components/contacto/FormLegal.astro';
import Beneficios from '@/components/contacto/Beneficios.astro';

const titulo = 'Pedir cita — Psicóloga en Granada especialista en TCA';
const descripcion =
  'Pide cita con Rosa Ruiz, psicóloga en Granada especialista en TCA. Sesiones online y presenciales. Contacto directo por WhatsApp o formulario. Respuesta en 24 h.';
const canonica = `${Astro.site}pedir-cita/`;
const imagenOG = `${Astro.site}open-graph/pedir-cita.png/`;

const esquema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  mainEntity: {
    '@type': 'MedicalBusiness',
    name: 'Rosa María Ruiz Cano, Psicóloga General Sanitaria',
    '@id': `${Astro.site}#localbusiness`,
    telephone: '+34674307408',
    email: 'rosamruizpsicologa@gmail.com',
    url: Astro.site,
    image: imagenOG,
    priceRange: '$$',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'C. Nécora, 7, Chana',
      addressLocality: 'Granada',
      postalCode: '18003',
      addressCountry: 'ES',
    },
    areaServed: [
      { '@type': 'City', name: 'Granada' },
      { '@type': 'Country', name: 'ES', description: 'Online' },
    ],
    openingHoursSpecification: [
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: 'Monday',
        opens: '09:00',
        closes: '20:30',
      },
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: 'Tuesday',
        opens: '09:00',
        closes: '20:30',
      },
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: 'Wednesday',
        opens: '09:00',
        closes: '20:30',
      },
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: 'Thursday',
        opens: '09:00',
        closes: '20:30',
      },
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: 'Friday',
        opens: '09:00',
        closes: '20:30',
      },
    ],
    sameAs: [
      'https://www.instagram.com/con.agallas/',
      'https://www.linkedin.com/in/rosa-maría-ruiz-cano/',
    ],
  },
};
---

<Layout
  titulo={titulo}
  descripcion={descripcion}
  canonica={canonica}
  imagenOG={imagenOG}
  esquema={esquema}
>
  <h1 class="sr-only">
    Pedir cita · Psicóloga en Granada especialista en TCA — Rosa María Ruiz Cano
  </h1>

  <section class="mx-auto 2xl:max-w-screen-2xl px-4 sm:px-6 md:px-8">
    <div class="lg:grid lg:grid-cols-[1fr_1fr] lg:gap-12 xl:gap-16">
      <div class="lg:self-start lg:sticky lg:top-36">
        <Beneficios />
      </div>

      <div class="mt-12 sm:mt-16 lg:mt-0">
        <FormularioContacto>
          <FormLegal />
        </FormularioContacto>
      </div>
    </div>
  </section>
</Layout>
