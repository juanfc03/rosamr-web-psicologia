---
import '../styles/global.css';

interface Props {
  titulo: string;
  descripcion: string;
  autor?: string;
  robots?: string;
  canonica: string;
  imagenOG?: string;
  esquema?: Record<string, unknown>;
}

const {
  titulo,
  descripcion,
  autor = 'Rosa María Ruiz Cano',
  robots = 'index, follow',
  canonica,
  imagenOG,
  esquema,
} = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{titulo}</title>
    <meta name="description" content={descripcion} />
    <meta name="author" content={autor} />
    <meta name="robots" content={robots} />

    <link rel="canonical" href={canonica} />

    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content={autor} />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonica} />
    {
      imagenOG && (
        <>
          <meta property="og:image" content={imagenOG} />
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
        </>
      )
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo} />
    <meta name="twitter:description" content={descripcion} />
    {imagenOG && <meta name="twitter:image" content={imagenOG} />}

    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Rosa - Psicóloga" />
    <link rel="manifest" href="/site.webmanifest" />

    {
      esquema && (
        <script type="application/ld+json" set:html={JSON.stringify(esquema)} />
      )
    }
  </head>
  <body class="min-h-screen flex flex-col bg-main-gradient">
    <main class="flex-1"><slot /></main>
  </body>
</html>
