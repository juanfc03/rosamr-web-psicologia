---
import { Image } from 'astro:assets';
import { legal, redes } from '@/data/pie';
import stampMundopsicologos from '@/assets/mundopsicologos-stamp.png';
---

<footer
  class="w-full border-t border-gray-400/40 bg-gray-200/10 text-oscuro mt-14 sm:mt-16 md:mt-20 lg:mt-24 xl:mt-28"
>
  <div
    class="grid grid-cols-1 gap-8 px-4 py-8 sm:grid-cols-2 sm:gap-10 sm:px-6 sm:py-10 lg:grid-cols-4 lg:px-8"
  >
    <section aria-label="Contacto" class="space-y-3">
      <h2 class="font-semibold text-tam-principal text-oscuro">
        Rosa María Ruiz Cano
      </h2>
      <p class="font-normal text-tam-reducido text-atenuado">
        Psicóloga General Sanitaria
      </p>

      <p class="text-tam-reducido leading-relaxed text-cuerpo">
        Acompañamiento psicológico profesional y humano. Sesiones online y
        presenciales bajo confidencialidad.
      </p>

      <address
        class="flex flex-col gap-y-1 text-tam-reducido text-cuerpo not-italic"
      >
        <span class="block font-medium text-oscuro">Contacto:</span>
        <span class="block">Granada, España</span>
        <ul class="space-y-4">
          <li>
            <a
              href="tel:+34674307408"
              aria-label="Llamar por teléfono a Rosa María Ruiz"
              class="text-primario underline underline-offset-2 hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-oscuro rounded-sm py-1"
            >
              Llamar por teléfono
            </a>
          </li>
          <li>
            <a
              href="mailto:rosamruizpsicologa@gmail.com"
              aria-label="Enviar correo a rosamruizpsicologa@gmail.com"
              class="text-primario underline underline-offset-2 hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-oscuro rounded-sm py-1"
            >
              rosamruizpsicologa@gmail.com
            </a>
          </li>
          <li>
            <a
              href="https://wa.me/34674307408?text=¡Hola Rosa!"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Hablar por WhatsApp (se abre en una pestaña nueva)"
              class="text-primario underline underline-offset-2 hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-oscuro rounded-sm py-1"
            >
              Hablar por WhatsApp
            </a>
          </li>
          <li>
            <a
              href="/pedir-cita/"
              aria-label="Formulario de contacto para pedir cita"
              class="text-primario underline underline-offset-2 hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-oscuro rounded-sm py-1"
            >
              Formulario de contacto
            </a>
          </li>
        </ul>
      </address>
    </section>

    <nav aria-label="Páginas legales" class="space-y-3 text-tam-reducido">
      <h2 class="font-semibold text-tam-principal text-oscuro">
        Páginas legales
      </h2>
      <ul class="space-y-2">
        {
          legal.map(item => (
            <li>
              <a
                href={item.href}
                aria-current={
                  Astro.url.pathname === item.href ? 'page' : undefined
                }
                class="text-cuerpo hover:text-primario hover:underline underline-offset-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-oscuro rounded-sm"
              >
                {item.etiqueta}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <section aria-label="Información legal" class="space-y-3 text-tam-reducido">
      <h2 class="font-semibold text-tam-principal text-oscuro">
        Información legal
      </h2>
      <dl class="space-y-2">
        <dt class="text-cuerpo">N.º de colegiada:</dt>
        <dd class="font-medium text-oscuro">AO-13788</dd>
        <dt class="text-cuerpo">Colegio Oficial de Psicología:</dt>
        <dd class="font-medium text-oscuro">Andalucía Occidental</dd>
      </dl>

      <a
        href="https://www.mundopsicologos.com/centros/rosa-maria-ruiz-cano?utm_source=450075&utm_medium=widget&utm_campaign=widget-company_stamp"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block"
        aria-label="Perfil de Rosa María Ruiz Cano en MundoPsicólogos (se abre en una pestaña nueva)"
      >
        <Image
          src={stampMundopsicologos}
          alt="Rosa María Ruiz Cano en MundoPsicólogos"
          class="h-auto w-full max-w-48"
          loading="lazy"
          decoding="async"
        />
      </a>

      <p class="text-tam-legal leading-snug text-atenuado">
        La información que compartas será tratada con absoluta confidencialidad
        y conforme a la normativa vigente en materia de protección de datos.
      </p>
    </section>

    <section aria-label="Redes" class="space-y-3 text-tam-reducido">
      <h2 class="font-semibold text-tam-principal text-oscuro">Redes</h2>
      <ul class="space-y-2">
        {
          redes.map(red => (
            <li>
              <a
                href={red.href}
                target="_blank"
                rel="me noopener noreferrer"
                aria-label={`${red.etiqueta} (se abre en una pestaña nueva)`}
                class="inline-flex items-center gap-2 text-cuerpo hover:text-primario focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-oscuro rounded-sm"
              >
                <span
                  class="block size-2.5 rounded-full bg-primario"
                  aria-hidden="true"
                />
                <span>{red.etiqueta}</span>
              </a>
            </li>
          ))
        }
      </ul>

      <p class="text-tam-legal leading-snug text-atenuado">
        No ofrezco atención psicológica de urgencia por redes sociales. En caso
        de riesgo inmediato para tu seguridad o la de otra persona, contacta con
        emergencias de tu país.
      </p>
    </section>
  </div>

  <div class="w-full border-t border-gray-400/40 bg-gray-100">
    <div
      class="flex flex-col items-center justify-between gap-4 px-4 py-4 text-center text-tam-legal text-cuerpo sm:flex-row sm:px-6 sm:py-6 sm:text-left lg:px-8"
    >
      <small class="leading-snug">
        &copy; <span id="anio-pie">{new Date().getFullYear()}</span> Rosa María Ruiz
        Cano &middot; Todos los derechos reservados
      </small>

      <p class="leading-snug">
        Hecho con cariño por
        <a
          href="https://www.linkedin.com/in/juan-fernández-ceacero-890627379"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn de Juan Fernández Ceacero (se abre en una pestaña nueva)"
          class="text-primario hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-oscuro rounded-sm"
        >
          Juan
        </a>
      </p>
    </div>
  </div>
</footer>

<script src="../scripts/footer-actualizar-fecha.ts"></script>
