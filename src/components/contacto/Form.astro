<div
  class="px-6 py-3 md:px-8 md:py-4 bg-white/20 rounded-2xl border border-white/30 shadow-lg"
>
  <header class="space-y-2 md:space-y-4">
    <h2 class="font-semibold text-tam-mediano text-oscuro text-center">
      Pide tu cita <span class="text-primario">ahora</span>
    </h2>

    <p class="mt-3 text-tam-principal leading-relaxed text-cuerpo text-justify">
      Rellena este formulario para solicitar una cita o enviarme tu consulta. Te
      contactaré para coordinar día y hora. Recuerda que también puedes
      contactarme por
      <a
        href="https://wa.me/34674307408?text=¡Hola Rosa!"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contactar por WhatsApp (se abre en una nueva pestaña)"
        class="text-primario underline underline-offset-2 hover:brightness-110"
      >
        WhatsApp
      </a>
      o
      <a
        href="mailto:rosamruizpsicologa@gmail.com"
        class="text-primario underline underline-offset-2 hover:brightness-110"
      >
        Email
      </a>.
    </p>
  </header>

  <form
    name="contacto"
    method="POST"
    class="mt-8 space-y-5"
    data-netlify="true"
    data-netlify-recaptcha="true"
    netlify-honeypot="bot-field"
  >
    <div class="hidden" aria-hidden="true">
      <label
        >No rellenes este campo: <input
          type="text"
          name="bot-field"
          autocomplete="off"
        /></label
      >
    </div>

    <div>
      <label class="etiqueta-formulario"
        >Nombre
        <input
          type="text"
          name="nombre"
          required
          minlength="2"
          maxlength="50"
          title="Introduce tu nombre y apellidos"
          autocomplete="name"
          class="entrada-formulario"
          placeholder="Tu nombre y apellidos"
        />
      </label>
    </div>

    <div>
      <label class="etiqueta-formulario"
        >Email
        <input
          type="email"
          name="email"
          required
          maxlength="100"
          title="Introduce un correo electrónico válido"
          autocomplete="email"
          inputmode="email"
          class="entrada-formulario"
          placeholder="tucorreo@ejemplo.com"
        />
      </label>
    </div>

    <div>
      <label class="etiqueta-formulario"
        >Número de teléfono
        <input
          type="tel"
          name="telefono"
          required
          minlength="9"
          maxlength="15"
          pattern="[+]?[0-9]{9,14}"
          autocomplete="tel"
          inputmode="tel"
          title="Introduce un número de teléfono válido (ej. 612345678 o +34612345678)"
          class="entrada-formulario"
          placeholder="+34 6XX XXX XXX"
        />
      </label>
    </div>

    <div>
      <label class="etiqueta-formulario"
        >Mensaje
        <textarea
          name="mensaje"
          rows="4"
          title="Introduce el mensaje"
          required
          minlength="10"
          maxlength="600"
          class="entrada-formulario resize-y"
          placeholder="Cuéntame brevemente en qué puedo ayudarte"></textarea>
      </label>
    </div>

    <div class="flex items-center gap-3">
      <input
        type="checkbox"
        id="acepto_privacidad"
        name="acepto_privacidad"
        required
        class="mt-0.5 size-6 rounded border border-gray-300 text-primario focus-visible:ring-2 focus-visible:ring-primario md:size-7"
      />
      <label for="acepto_privacidad" class="text-tam-principal text-atenuado">
        He leído y acepto la
        <a
          href="/politica-de-privacidad/"
          class="text-primario underline underline-offset-2 hover:brightness-110"
          >política de privacidad</a
        >.
      </label>
    </div>

    <div data-netlify-recaptcha="true" transition:persist></div>

    <button
      type="submit"
      class="px-4 py-3 md:px-5 md:py-4 w-full text-center font-medium text-white bg-primario rounded-lg hover:brightness-110 focus:outline-none focus-visible:ring-2 focus-visible:ring-primario cursor-pointer text-tam-principal"
    >
      Enviar solicitud
    </button>
  </form>

  <slot />
</div>

<div
  id="form-toast"
  class="pointer-events-none fixed bottom-6 right-6 z-50 max-w-sm translate-x-full rounded-lg px-5 py-4 text-tam-principal text-white shadow-lg opacity-0 transition-all duration-500"
  role="status"
  aria-live="polite"
>
</div>

<script src="../../scripts/formulario-contacto.ts"></script>

<style>
  @reference "@/styles/global.css";

  .entrada-formulario {
    @apply mt-1 block w-full rounded-lg border border-gray-300 bg-white/60 px-3 py-2 text-cuerpo placeholder:text-sutil/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-primario focus-visible:border-primario;
  }

  .etiqueta-formulario {
    @apply block text-tam-principal text-cuerpo font-medium;
  }

  .toast-exito {
    background-color: #15803d;
  }

  .toast-error {
    background-color: #991b1b;
  }

  #form-toast.mostrar {
    opacity: 1;
    translate: 0;
    pointer-events: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    #form-toast {
      transition: none;
    }
  }
</style>
